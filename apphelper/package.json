    "@stripe/stripe-js": "^7.4.0",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "@types/react-csv": "^1.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/slug": "^5.0.9",
    "@vitejs/plugin-react": "^4.7.0",
    "copyfiles": "^2.4.1",
