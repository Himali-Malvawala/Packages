{
  "name": "@churchapps/texting",
  "version": "0.1.0",
  "type": "module",
  "description": "SMS texting provider abstraction for ChurchApps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "churchapps",
    "texting",
    "sms",
    "clearstream",
    "textinchurch"
  ],
  "author": "ChurchApps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChurchApps/Packages.git",
    "directory": "texting"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
