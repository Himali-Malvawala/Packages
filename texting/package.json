{
  "name": "@churchapps/texting",
  "version": "0.2.0",
  "type": "module",
  "description": "SMS texting provider abstraction for ChurchApps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "node -e \"if(!(process.env.npm_config_user_agent||'').startsWith('yarn')){console.error('\\n[texting] This project uses Yarn (Berry). Run \\'yarn install\\' instead of npm/pnpm.\\n');process.exit(1)}\"",
    "build": "tsup",
    "dev": "vite",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "churchapps",
    "texting",
    "sms",
    "clearstream",
    "textinchurch"
  ],
  "author": "ChurchApps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChurchApps/Packages.git",
    "directory": "texting"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.15.0",
  "dependencies": {
    "axios": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.6"
  },
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    }
  }
}
